def generate_train_data(number: str) -> Dict:
    stations = [
        'New Delhi', 'Agra Cantt', 'Jhansi', 'Bhopal', 'Nagpur',
        'Itarsi', 'Bhusaval', 'Manmad', 'Kalyan', 'Mumbai CST',
        'Lucknow', 'Kanpur', 'Allahabad', 'Varanasi', 'Patna',
        'Jaipur', 'Ajmer', 'Jodhpur', 'Bikaner', 'Amritsar',
        'Chandigarh', 'Ludhiana', 'Jammu', 'Katra', 'Srinagar',
    ]
    current = random.choice(stations)
    next_station = random.choice([s for s in stations if s != current])
    return {
        'number': number,
        'name': f'Express {number}',
        'current_location': current,
        'next_station': next_station,
        'eta': f'{random.randint(10, 120)} minutes',
        'status': random.choice(['Running', 'Delayed', 'On Time']),
        'platform': random.randint(1, 8),
        'speed': random.randint(40, 120),
        'last_updated': datetime.now().isoformat(),
    }

def generate_mandi_data(commodity: str) -> Dict:
    markets = [
        'Azadpur Mandi (Delhi)', 'Vashi Mandi (Mumbai)', 'Koyambedu (Chennai)',
        'Kolkata Sealdah', 'Bangalore Yeshwanthpur', 'Hyderabad Moosapet',
        'Ahmedabad Kalupur', 'Pune Market Yard', 'Jaipur Muhana',
        'Lucknow Aminabad', 'Kanpur Jajmau', 'Indore Chhawani',
    ]
    base_prices = {
        'onion': 2500, 'pyaj': 2500, 'tomato': 1500, 'tamatar': 1500,
        'potato': 1200, 'aloo': 1200, 'wheat': 2200, 'gehu': 2200,
        'rice': 3500, 'chawal': 3500, 'corn': 1800, 'makka': 1800,
        'soybean': 4500, 'mustard': 5200, 'cotton': 6200, 'kapas': 6200,
        'sugarcane': 300, 'ganna': 300, 'garlic': 8000, 'ginger': 12000,
    }
    base = base_prices.get(commodity.lower(), random.randint(1000, 5000))
    price = base + random.randint(-500, 500)
    return {
        'commodity': commodity.title(),
        'price': price,
        'unit': 'per quintal',
        'market': random.choice(markets),
        'trend': random.choice(['Up', 'Down', 'Stable']),
        'change': round(random.uniform(-5, 5), 2),
        'last_updated': datetime.now().isoformat(),
    }

def generate_weather_data(city: str) -> Dict:
    conditions = ['Clear', 'Partly Cloudy', 'Cloudy', 'Rainy', 'Thunderstorm', 'Haze']
    return {
        'city': city.title(),
        'temp': random.randint(15, 45),
        'feels_like': random.randint(15, 45),
        'condition': random.choice(conditions),
        'humidity': random.randint(30, 90),
        'wind_speed': random.randint(5, 30),
        'wind_direction': random.choice(['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW']),
        'visibility': random.randint(5, 10),
        'uv_index': random.randint(1, 11),
        'forecast': [
            {'day': 'Tomorrow', 'temp': random.randint(15, 45), 'condition': random.choice(conditions)},
            {'day': 'Day After', 'temp': random.randint(15, 45), 'condition': random.choice(conditions)},
        ],
        'last_updated': datetime.now().isoformat(),
    }

def generate_stock_data(symbol: str) -> Dict:
    companies = {
        'RELIANCE': 2450, 'TCS': 3850, 'INFY': 1520, 'HDFCBANK': 1680,
        'ICICIBANK': 1050, 'SBIN': 720, 'BHARTIARTL': 980, 'ITC': 420,
        'HINDUNILVR': 2450, 'LT': 2850, 'AXISBANK': 1050, 'KOTAKBANK': 1780,
        'BAJFINANCE': 7200, 'TATAMOTORS': 780, 'MARUTI': 10500, 'SUNPHARMA': 1250,
        'WIPRO': 450, 'HCLTECH': 1380, 'ADANIENT': 2850, 'COALINDIA': 420,
        'ONGC': 250, 'NTPC': 320, 'POWERGRID': 280, 'IOC': 150,
    }
    base = companies.get(symbol.upper(), random.randint(100, 5000))
    change = round(random.uniform(-5, 5), 2)
    price = round(base * (1 + change/100), 2)
    return {
        'symbol': symbol.upper(),
        'name': f'{symbol.upper()} Ltd.',
        'price': price,
        'change': change,
        'change_percent': change,
        'volume': random.randint(1000000, 50000000),
        'market_cap': round(random.uniform(1000, 20000), 2),
        'day_high': round(price * 1.02, 2),
        'day_low': round(price * 0.98, 2),
        '52w_high': round(price * 1.5, 2),
        '52w_low': round(price * 0.6, 2),
        'last_updated': datetime.now().isoformat(),
    }

def generate_cricket_data() -> Dict:
    teams = ['India', 'Australia', 'England', 'Pakistan', 'South Africa', 'New Zealand', 'Sri Lanka', 'West Indies']
    team1, team2 = random.sample(teams, 2)
    score1 = f"{random.randint(120, 350)}/{random.randint(0, 9)}"
    score2 = f"{random.randint(50, 300)}/{random.randint(0, 9)}"
    overs = f"{random.randint(10, 50)}.{random.randint(0, 5)}"
    return {
        'match_id': f'live_{random.randint(1000, 9999)}',
        'team1': team1,
        'team2': team2,
        'score': f"{team1}: {score1} vs {team2}: {score2}",
        'team1_score': score1,
        'team2_score': score2,
        'overs': overs,
        'status': random.choice(['Live', 'In Progress', 'Break', 'Match Ended']),
        'venue': random.choice(['Wankhede', 'Eden Gardens', 'M Chinnaswamy', 'Arun Jaitley', 'Chepauk']),
        'last_updated': datetime.now().isoformat(),
    }

