@dataclass
class IntentResult:
    intent: str
    confidence: float
    entities: Dict[str, Any]
    api_endpoint: str
    response_template: str
    language: str = 'hi'


class IntentDetector:
    def __init__(self):
        self.intents = INTENTS
        self.confidence_threshold = CONFIDENCE_THRESHOLD

    def detect_intent(self, text: str, language: str = 'hi') -> IntentResult:
        text_lower = text.lower().strip()
        best_intent = 'general'
        best_confidence = 0.0
        best_entities = {}

        for intent_name, intent_config in self.intents.items():
            if intent_name == 'general':
                continue

            confidence, entities = self._calculate_confidence(text_lower, intent_config, language)

            if confidence > best_confidence:
                best_confidence = confidence
                best_intent = intent_name
                best_entities = entities

        if best_confidence < self.confidence_threshold:
            best_intent = 'general'
            best_entities = {'query': text}

        intent_config = self.intents[best_intent]
        api_endpoint = self._format_endpoint(intent_config['api_endpoint'], best_entities)

        return IntentResult(
            intent=best_intent,
            confidence=best_confidence,
            entities=best_entities,
            api_endpoint=api_endpoint,
            response_template=intent_config['response_template'],
            language=language
        )

    def _calculate_confidence(self, text: str, intent_config: Dict, language: str) -> Tuple[float, Dict]:
        confidence = 0.0
        entities = {}

        keywords = intent_config['keywords']
        keyword_matches = sum(1 for kw in keywords if kw.lower() in text)
        keyword_confidence = keyword_matches / max(len(keywords), 1) * 0.6
        confidence += keyword_confidence

        patterns = intent_config.get('patterns', [])
        for pattern in patterns:
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                confidence += 0.4
                groups = match.groups()
                if groups:
                    entities['number'] = groups[0] if len(groups) > 0 else None
                    entities['commodity'] = groups[0] if len(groups) > 0 else None
                    entities['city'] = groups[0] if len(groups) > 0 else None
                    entities['symbol'] = groups[0] if len(groups) > 0 else None
                    entities['sign'] = groups[0] if len(groups) > 0 else None
                break

        numbers = re.findall(r'\d+', text)
        if numbers and 'train' in intent_config['keywords']:
            entities['number'] = numbers[0]
            confidence += 0.2

        if 'mandi' in intent_config['keywords']:
            commodities = self._extract_commodity(text)
            if commodities:
                entities['commodity'] = commodities[0]
                confidence += 0.3

        if 'weather' in intent_config['keywords']:
            cities = self._extract_city(text)
            if cities:
                entities['city'] = cities[0]
                confidence += 0.3

        if 'stock' in intent_config['keywords']:
            symbols = self._extract_stock_symbol(text)
            if symbols:
                entities['symbol'] = symbols[0]
                confidence += 0.3

        if 'horoscope' in intent_config['keywords']:
            signs = self._extract_zodiac_sign(text)
            if signs:
                entities['sign'] = signs[0]
                confidence += 0.3

        return min(confidence, 1.0), entities

    def _extract_commodity(self, text: str) -> list:
        commodities = [
            'onion', 'pyaj', 'tomato', 'tamatar', 'potato', 'aloo',
            'wheat', 'gehu', 'rice', 'chawal', 'corn', 'makka',
            'soybean', 'soya', 'mustard', 'sarso', 'cotton', 'kapas',
            'sugarcane', 'ganna', 'garlic', 'lahsun', 'ginger', 'adrak',
        ]
        return [c for c in commodities if c.lower() in text.lower()]

    def _extract_city(self, text: str) -> list:
        cities = [
            'delhi', 'mumbai', 'bangalore', 'bengaluru', 'hyderabad',
            'chennai', 'kolkata', 'pune', 'jaipur', 'lucknow',
            'kanpur', 'nagpur', 'indore', 'thane', 'bhopal',
            'visakhapatnam', 'vadodara', 'firozabad', 'ludhiana',
            'rajkot', 'agra', 'siliguri', 'durgapur', 'chandigarh',
            'dehradun', 'noida', 'gurgaon', 'faridabad', 'ghaziabad',
            'meerut', 'varanasi', 'patna', 'ranchi', 'guwahati',
            'shimla', 'jammu', 'srinagar', 'amritsar', 'jalandhar',
            'allahabad', 'prayagraj', 'gorakhpur', 'aligarh', 'bareilly',
            'moradabad', 'saharanpur', 'muzaffarnagar', 'mathura',
        ]
        return [c.title() for c in cities if c.lower() in text.lower()]

    def _extract_stock_symbol(self, text: str) -> list:
        stocks = [
            'reliance', 'tcs', 'infosys', 'hdfc', 'icici', 'sbi',
            'bharti', 'airtel', 'itc', 'hul', 'lt', 'axis',
            'kotak', 'bajaj', 'tatamotors', 'maruti', 'sunpharma',
            'drreddy', 'cipla', 'wipro', 'techmahindra', 'hcltech',
            'adani', 'coalindia', 'ongc', 'ntpc', 'powergrid',
            'ioc', 'bpcl', 'hpcl', 'gail', 'nifty', 'sensex',
        ]
        return [s.upper() for s in stocks if s.lower() in text.lower()]

    def _extract_zodiac_sign(self, text: str) -> list:
        signs = [
            'mesh', 'vrish', 'mithun', 'kark', 'singh', 'kanya',
            'tula', 'vrishchik', 'dhanu', 'makara', 'kumbh', 'meen',
            'aries', 'taurus', 'gemini', 'cancer', 'leo', 'virgo',
            'libra', 'scorpio', 'sagittarius', 'capricorn', 'aquarius', 'pisces',
        ]
        return [s.title() for s in signs if s.lower() in text.lower()]

    def _format_endpoint(self, endpoint: str, entities: Dict) -> str:
        try:
            return endpoint.format(**entities)
        except KeyError:
            return endpoint

    def detect_language(self, text: str) -> str:
        hindi_chars = set('अआइईउऊऋएऐओऔअंअःकखगघङचछजझञटठडढणतथदधनपफबभमयरलवशषसह')
        text_chars = set(text)

        if any(char in hindi_chars for char in text_chars):
            return 'hi'

        hindi_words = ['hai', 'hain', 'ka', 'ki', 'ke', 'ko', 'se', 'mein', 'me', 'par', 'aur', 'ya']
        if any(word in text.lower() for word in hindi_words):
            return 'hi'

        return 'en'

    def process_voice_input(self, transcript: str) -> Dict[str, Any]:
        language = self.detect_language(transcript)
        intent_result = self.detect_intent(transcript, language)

        return {
            'input': transcript,
            'language': language,
            'intent': intent_result.intent,
            'confidence': intent_result.confidence,
            'entities': intent_result.entities,
            'api_endpoint': intent_result.api_endpoint,
            'response_template': intent_result.response_template,
            'should_speak': True,
            'speak_language': language
        }


