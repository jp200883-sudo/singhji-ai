class VoiceFormatter:
    @staticmethod
    def format_train_response(data: Dict) -> str:
        train_no = data.get('number', 'Unknown')
        location = data.get('current_location', 'Unknown')
        eta = data.get('eta', 'Unknown')
        return f"ट्रेन {train_no} अभी {location} स्टेशन पर है। अनुमानित आगमन समय: {eta}।"

    @staticmethod
    def format_mandi_response(data: Dict) -> str:
        commodity = data.get('commodity', 'Unknown')
        price = data.get('price', 'Unknown')
        market = data.get('market', 'Unknown')
        return f"{commodity} का वर्तमान भाव ₹{price} प्रति क्विंटल है। बाजार: {market}।"

    @staticmethod
    def format_weather_response(data: Dict) -> str:
        city = data.get('city', 'Unknown')
        condition = data.get('condition', 'Unknown')
        temp = data.get('temp', 'Unknown')
        humidity = data.get('humidity', 'Unknown')
        return f"{city} में मौसम {condition} है। तापमान {temp} डिग्री सेल्सियस। नमी {humidity} प्रतिशत।"

    @staticmethod
    def format_stock_response(data: Dict) -> str:
        symbol = data.get('symbol', 'Unknown')
        price = data.get('price', 'Unknown')
        change = data.get('change', 'Unknown')
        direction = 'बढ़ा' if float(change) > 0 else 'घटा'
        return f"{symbol} का भाव ₹{price} है। {change} प्रतिशत {direction}।"

    @staticmethod
    def format_cricket_response(data: Dict) -> str:
        team1 = data.get('team1', 'Unknown')
        team2 = data.get('team2', 'Unknown')
        score = data.get('score', 'Unknown')
        status = data.get('status', 'Unknown')
        return f"लाइव मैच: {team1} बनाम {team2}। स्कोर: {score}। स्थिति: {status}।"

    @staticmethod
    def format_horoscope_response(data: Dict) -> str:
        sign = data.get('sign', 'Unknown')
        prediction = data.get('prediction', 'Unknown')
        lucky = data.get('lucky_number', 'Unknown')
        return f"{sign} राशिफल: {prediction}। आज का भाग्यशाली अंक: {lucky}।"

    @staticmethod
    def format_news_response(data: Dict) -> str:
        headlines = data.get('headlines', [])
        source = data.get('source', 'Unknown')
        if isinstance(headlines, list):
            headlines_text = '। '.join(headlines[:3])
        else:
            headlines_text = str(headlines)
        return f"आज की प्रमुख खबरें: {headlines_text}। स्रोत: {source}।"

    @staticmethod
    def format_guard_alert(data: Dict) -> str:
        return data.get('alert_message', '✅ सब कुछ सामान्य है।')


# ============================================================================
# TRIAL MANAGER
# ============================================================================

class TrialManager:
    def __init__(self):
        self.users = {}

    def get_user_trial(self, user_id: str, country_code: str = 'IN'):
        if user_id not in self.users:
            trial_info = TrialConfig.get_trial_info(country_code, user_id)
            self.users[user_id] = {
                'user_id': user_id,
                'country': country_code,
                'trial_start': datetime.now().isoformat(),
                'trial_info': trial_info,
                'is_premium': False,
                'trial_active': True,
            }
        return self.users[user_id]

    def check_feature_access(self, user_id: str, feature: str) -> Dict:
        user = self.users.get(user_id)
        if not user:
            return {'access': True, 'reason': 'new_user'}

        if user['trial_info']['category'] == 'ultra_max':
            if datetime.now() < TrialConfig.PAYMENT_START_DATE:
                return {'access': True, 'reason': 'ultra_max_free'}

        trial_start = datetime.fromisoformat(user['trial_start'])
        trial_months = user['trial_info']['trial_months']
        trial_end = trial_start + timedelta(days=30 * trial_months)

        if datetime.now() < trial_end:
            return {'access': True, 'reason': 'trial_active'}

        if TrialConfig.is_payment_active():
            if user['is_premium']:
                return {'access': True, 'reason': 'premium'}
            else:
                return {
                    'access': False,
                    'reason': 'trial_expired',
                    'message': '⏰ आपका ट्रायल समाप्त हो गया! Premium अपग्रेड करें।',
                    'upgrade_url': '/premium'
                }

        return {'access': True, 'reason': 'payment_not_active'}


