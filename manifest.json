@app.route('/api/voice/process', methods=['POST'])
def process_voice():
    data = request.json
    transcript = data.get('transcript', '')
    user_id = data.get('user_id', 'anonymous')
    country = data.get('country', 'IN')

    trial = trial_manager.get_user_trial(user_id, country)
    access = trial_manager.check_feature_access(user_id, 'voice')

    if not access['access']:
        return jsonify({
            'success': False,
            'message': access['message'],
            'upgrade_required': True,
        })

    result = intent_detector.process_voice_input(transcript)
    api_response = auto_call_api(result)
    voice_response = format_voice_response(result['intent'], api_response)

    return jsonify({
        'success': True,
        'input': transcript,
        'intent': result['intent'],
        'confidence': result['confidence'],
        'entities': result['entities'],
        'api_response': api_response,
        'voice_response': voice_response,
        'language': result['language'],
        'should_speak': True,
        'trial_info': trial['trial_info'],
    })


def auto_call_api(intent_result: Dict) -> Dict:
    intent = intent_result['intent']
    entities = intent_result['entities']

    if intent == 'train':
        return generate_train_data(entities.get('number', '12309'))
    elif intent == 'mandi':
        return generate_mandi_data(entities.get('commodity', 'onion'))
    elif intent == 'weather':
        return generate_weather_data(entities.get('city', 'Delhi'))
    elif intent == 'stock':
        return generate_stock_data(entities.get('symbol', 'RELIANCE'))
    elif intent == 'cricket':
        return generate_cricket_data()
    elif intent == 'horoscope':
        return generate_horoscope_data(entities.get('sign', 'Mesh'))
    elif intent == 'news':
        return generate_news_data()
    else:
        return {'message': 'मैं आपकी मदद कैसे कर सकता हूँ?'}


def format_voice_response(intent: str, data: Dict) -> str:
    if intent == 'train':
        return voice_formatter.format_train_response(data)
    elif intent == 'mandi':
        return voice_formatter.format_mandi_response(data)
    elif intent == 'weather':
        return voice_formatter.format_weather_response(data)
    elif intent == 'stock':
        return voice_formatter.format_stock_response(data)
    elif intent == 'cricket':
        return voice_formatter.format_cricket_response(data)
    elif intent == 'horoscope':
        return voice_formatter.format_horoscope_response(data)
    elif intent == 'news':
        return voice_formatter.format_news_response(data)
    else:
        return data.get('message', 'मैं आपकी मदद कैसे कर सकता हूँ?')


