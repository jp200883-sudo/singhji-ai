            'should_vibrate': False,
            'should_sound': False,
            'priority': 'low',
        }

    def generate_alert(self, analysis: Dict[str, Any]) -> Dict[str, Any]:
        alert_type = analysis.get('alert_type', 'normal')
        alert_config = ALERT_TYPES.get(alert_type, ALERT_TYPES['normal'])
        alert_message = ALERT_MESSAGES.get(alert_type, '✅ सब कुछ सामान्य है।')
        vibration_pattern = VIBRATION_PATTERNS.get(alert_config['priority'], [100])

        return {
            'type': alert_type,
            'priority': alert_config['priority'],
            'message': alert_message,
            'vibrate': alert_config['vibrate'],
            'sound': alert_config['sound'],
            'vibration_pattern': vibration_pattern,
            'timestamp': datetime.now().isoformat(),
        }


