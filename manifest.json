<script>
const micBtn=document.getElementById('micBtn');
const statusText=document.getElementById('statusText');
const responseArea=document.getElementById('responseArea');
const responseText=document.getElementById('responseText');
const speakBtn=document.getElementById('speakBtn');
const alertBox=document.getElementById('alertBox');
const alertText=document.getElementById('alertText');
let recognition;
let isRecording=false;
let currentResponse='';

if('webkitSpeechRecognition' in window||'SpeechRecognition' in window){
const SpeechRecognition=window.SpeechRecognition||window.webkitSpeechRecognition;
recognition=new SpeechRecognition();
recognition.continuous=false;
recognition.interimResults=true;
recognition.lang='hi-IN';
recognition.onstart=()=>{isRecording=true;micBtn.classList.add('recording');statusText.textContent='🔴 सुन रहा हूँ...'};
recognition.onend=()=>{isRecording=false;micBtn.classList.remove('recording');statusText.textContent='"Train 12309 kahan hai?" बोलो...'};
recognition.onresult=(event)=>{
let transcript='';
for(let i=event.resultIndex;i<event.results.length;i++){transcript+=event.results[i][0].transcript}
statusText.textContent='📝 '+transcript;
if(event.results[0].isFinal){processVoiceInput(transcript)}
};
recognition.onerror=(event)=>{statusText.textContent='❌ Error: '+event.error;isRecording=false;micBtn.classList.remove('recording')};
}

micBtn.addEventListener('click',()=>{
if(!recognition){statusText.textContent='❌ Voice recognition not supported';return}
if(isRecording){recognition.stop()}else{recognition.start()}
});

async function processVoiceInput(transcript){
statusText.textContent='⏳ Processing...';
try{
const response=await fetch('/api/voice/process',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({transcript:transcript,user_id:'web_user',country:'IN'})});
const data=await response.json();
if(data.success){
currentResponse=data.voice_response;
responseText.textContent=currentResponse;
responseArea.style.display='block';
statusText.textContent='✅ '+data.intent+' detected ('+Math.round(data.confidence*100)+'%)';
speakText(currentResponse);
}else{statusText.textContent=data.message}
}catch(error){statusText.textContent='❌ Error: '+error.message}
}

function speakText(text){
if('speechSynthesis' in window){
window.speechSynthesis.cancel();
const utterance=new SpeechSynthesisUtterance(text);
utterance.lang='hi-IN';utterance.rate=1.0;utterance.pitch=1.0;utterance.volume=1.0;
const voices=window.speechSynthesis.getVoices();
const hindiVoice=voices.find(v=>v.lang.includes('hi')||v.lang.includes('Hindi'));
if(hindiVoice){utterance.voice=hindiVoice}
window.speechSynthesis.speak(utterance);
}
}

speakBtn.addEventListener('click',()=>{if(currentResponse){speakText(currentResponse)}});

function quickCommand(type){
const commands={'train':'Train 12309 kahan hai','mandi':'Pyaj ka bhav kya hai','weather':'Delhi ka mausam kaisa hai','stock':'Reliance ka share price','cricket':'Live score batao','horoscope':'Aaj ka rashifal','news':'Aaj ki khabar sunao','chat':'Namaste Singh Ji'};
const text=commands[type];statusText.textContent='📝 '+text;processVoiceInput(text);
}

async function analyzeImage(input){
const file=input.files[0];if(!file)return;
const uploadArea=document.getElementById('uploadArea');uploadArea.innerHTML='<p>🔍 Analyzing image...</p>';
const reader=new FileReader();
reader.onload=async(e)=>{
const base64=e.target.result.split(',')[1];
try{
const response=await fetch('/api/vision/analyze',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({image:base64})});
const data=await response.json();
if(data.alert&&data.alert.priority!=='low'){
alertText.textContent=data.alert.message;alertBox.style.display='block';
if(navigator.vibrate&&data.alert.vibrate){navigator.vibrate(data.alert.vibration_pattern)}
speakText(data.alert.message);uploadArea.innerHTML='<p style="color:#ff4444;">⚠️ Alert Generated!</p>';
}else{uploadArea.innerHTML='<p style="color:#4CAF50;">✅ No threats detected</p>'}
}catch(error){uploadArea.innerHTML='<p style="color:#ff4444;">❌ Error analyzing image</p>'}
};
reader.readAsDataURL(file);
}

if('serviceWorker' in navigator){navigator.serviceWorker.register('/service-worker.js').then(reg=>console.log('SW registered')).catch(err=>console.log('SW error',err))}
if('Notification' in window){Notification.requestPermission()}
window.speechSynthesis.onvoiceschanged=()=>{console.log('Voices loaded')};
</script>
</body>
</html>
"""


# Error Handlers
@app.errorhandler(404)
def not_found(error):
    return jsonify({'success': False, 'error': 'Not found'}), 404

@app.errorhandler(500)
def internal_error(error):
    return jsonify({'success': False, 'error': 'Internal server error'}), 500


# Main
if __name__ == '__main__':
    port = int(os.environ.get('PORT', 5000))
    app.run(host='0.0.0.0', port=port, debug=True)
