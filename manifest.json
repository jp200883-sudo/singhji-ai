# Service Worker
@app.route('/service-worker.js')
def service_worker():
    sw_js = """const CACHE_NAME = 'singhji-ai-v1';
const urlsToCache = ['/', '/static/style.css', '/static/app.js', '/manifest.json'];
self.addEventListener('install', event => {
    event.waitUntil(caches.open(CACHE_NAME).then(cache => cache.addAll(urlsToCache)));
});
self.addEventListener('fetch', event => {
    event.respondWith(caches.match(event.request).then(response => response || fetch(event.request)));
});
self.addEventListener('push', event => {
    const data = event.data.json();
    self.registration.showNotification(data.title, {
        body: data.body, icon: '/static/icon-192x192.png', badge: '/static/badge-72x72.png',
        vibrate: data.vibrate || [200, 100, 200], data: data.data
    });
});
"""
    return sw_js, 200, {'Content-Type': 'application/javascript'}


